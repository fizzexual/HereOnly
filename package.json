{
  "name": "hereonly",
  "version": "0.4.0",
  "description": "Make your LAN a vault. Agent-less, zero-install access control that gates local services to the physical network segment — verified by ARP/NDP adjacency, MAC-pinned session tokens, and segment fingerprinting, with a tamper-evident physical-access audit log. Use it as middleware, a reverse proxy, or forward-auth for nginx/Caddy/Traefik. No agent, no cloud, no IdP.",
  "keywords": [
    "access-control",
    "arp",
    "ndp",
    "subnet",
    "lan",
    "l2",
    "physical-presence",
    "segment",
    "network-fingerprint",
    "mac-binding",
    "audit-log",
    "forward-auth",
    "nginx",
    "caddy",
    "traefik",
    "middleware",
    "reverse-proxy",
    "zero-trust",
    "air-gapped",
    "homelab"
  ],
  "license": "MIT",
  "author": "Fizzexual",
  "homepage": "https://github.com/fizzexual/HereOnly",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fizzexual/HereOnly.git"
  },
  "bugs": {
    "url": "https://github.com/fizzexual/HereOnly/issues"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./middleware": "./src/server/middleware.js",
    "./proxy": "./src/server/proxy.js",
    "./auth": "./src/server/authserver.js",
    "./hub": "./src/hub/index.js",
    "./config": "./src/config.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "hereonly": "bin/hereonly.js"
  },
  "files": [
    "src/",
    "bin/",
    "integrations/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test \"test/**/*.test.js\"",
    "test:unit": "node --test \"test/unit/**/*.test.js\"",
    "test:integration": "node --test \"test/integration/**/*.test.js\"",
    "doctor": "node bin/hereonly.js doctor",
    "status": "node bin/hereonly.js status"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {},
  "devDependencies": {}
}
