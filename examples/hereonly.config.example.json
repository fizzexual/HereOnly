{
  "target": "http://127.0.0.1:3000",
  "port": 7000,
  "host": "0.0.0.0",
  "requireArp": true,
  "includeWifi": true,
  "failClosed": true,
  "tokenTtlSeconds": 1800,
  "secretFile": ".hereonly/secret",
  "auditFile": ".hereonly/audit.log",
  "signAudit": true,
  "rateLimit": { "capacity": 60, "refillPerSec": 30 },
  "extraAllowCidrs": [],
  "denyCidrs": [],
  "network": {
    "allowedSsids": [],
    "allowedGatewayMacs": [],
    "allowedFingerprints": []
  },
  "policies": [
    { "match": { "path": "/admin" }, "overrides": { "network": { "allowedSsids": ["Ops"] } } }
  ],
  "trustedProxies": ["127.0.0.1/32"],
  "logLevel": "info"
}
